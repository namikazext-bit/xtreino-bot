const { 
    default: makeWASocket, 
    useMultiFileAuthState, 
    delay, 
    PHONENUMBER_MCC 
} = require("@whiskeysockets/baileys");
const pino = require("pino");

async function connectToWhatsApp() {
    const { state, saveCreds } = await useMultiFileAuthState('session');

    const sock = makeWASocket({
        logger: pino({ level: 'silent' }),
        auth: state,
        // Isso impede que o bot tente gerar QR Code no terminal do Railway
        browser: ["Ubuntu", "Chrome", "20.0.04"]
    });

    // Lógica para Pareamento por Código
    // Verificamos se não há credenciais registradas (primeiro acesso)
    if (!sock.authState.creds.registered) {
        const phoneNumber = "55XXXXXXXXXXX"; // Substitua pelo seu número com DDD

        // Um pequeno delay garante que o socket esteja pronto para a requisição
        await delay(5000); 

        try {
            const code = await sock.requestPairingCode(phoneNumber);
            console.log(`\n=========================================`);
            console.log(`📱 SEU CÓDIGO DE PAREAMENTO: ${code}`);
            console.log(`=========================================\n`);
        } catch (error) {
            console.error("Erro ao solicitar código de pareamento:", error);
        }
    }

    sock.ev.on('creds.update', saveCreds);

    sock.ev.on('connection.update', (update) => {
        const { connection, lastDisconnect } = update;
        if (connection === 'close') {
            console.log("Conexão fechada, tentando reconectar...");
            connectToWhatsApp();
        } else if (connection === 'open') {
            console.log("✅ Bot conectado com sucesso!");
        }
    });

    return sock;
}

connectToWhatsApp();
